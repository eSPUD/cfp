# --- Secrets: NEVER commit ---
.keys/
*.key
*.agekey

# --- Build output (generated by scripts/build.py) ---
site/

# --- Decrypted plaintext (safety net) ---
# If you ever decrypt in place to a *.dec.yaml file, it won't be committed.
data/*.dec.yaml
*.decrypted

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
